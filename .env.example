# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Use this prefix for Vercel/Public deployments.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_MODEL: Set this to "gemini-1.5-flash" or "gemini-2.0-flash" for Vercel.
# Default in code is "gemini-3-flash-preview" for AI Studio.
VITE_GEMINI_MODEL="gemini-1.5-flash"
